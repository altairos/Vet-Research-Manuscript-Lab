# Application environment: development, test, or production
VET_LAB_ENV=development

# Database URL. SQLite is the default for local development.
# For production, use PostgreSQL (requires psycopg2 or psycopg and optional
# langgraph-checkpoint-postgres):
#   VET_LAB_DATABASE_URL=postgresql://user:password@localhost:5432/vet_lab
VET_LAB_DATABASE_URL=sqlite:///./vet_lab.db

# Local paths. Do not point these at folders containing unapproved real data.
VET_LAB_ARTIFACT_ROOT=./artifacts
VET_LAB_CHECKPOINT_PATH=./artifacts/checkpoints.sqlite

# Connection pool settings (PostgreSQL only; ignored by SQLite).
VET_LAB_DB_POOL_SIZE=5
VET_LAB_DB_MAX_OVERFLOW=10
VET_LAB_DB_POOL_RECYCLE=1800

# External integrations (configure in later phases; never commit real values)
ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=
ZOTERO_LIBRARY_TYPE=user
LLM_API_KEY=
